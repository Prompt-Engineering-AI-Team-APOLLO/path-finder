# =============================================================================
#  Pathfinder API — Environment Variables
#  Copy this file:  cp .env.example .env
#
#  NOTE on DATABASE_URL / REDIS_URL:
#   • Inside Docker  → uses hostnames "db" and "redis" (set by docker-compose)
#   • Running locally → change to "localhost" in your .env
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Pathfinder API"
APP_VERSION="1.0.0"
ENVIRONMENT=development       # development | production | test
DEBUG=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: Replace before deploying!
# Generate a strong key with:   openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Docker:  postgresql+asyncpg://postgres:postgres@db:5432/pathfinder
# Local:   postgresql+asyncpg://postgres:postgres@localhost:5432/pathfinder
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pathfinder
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
# Docker:  redis://redis:6379/0
# Local:   redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# ── Pinecone (optional — leave blank to disable) ──────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=pathfinder-index

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text               # text (dev-friendly) | json (production)
