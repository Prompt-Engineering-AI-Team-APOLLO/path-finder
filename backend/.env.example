# =============================================================================
#  Pathfinder API — Environment Variables
#  Copy this file:  cp .env.example .env
#
#  NOTE on DATABASE_URL / REDIS_URL:
#   • Inside Docker  → uses hostnames "db" and "redis" (set by docker-compose)
#   • Running locally → change to "localhost"
#   • Supabase        → use the Session Mode pooler URL (port 5432) with SSL=true
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Pathfinder API"
APP_VERSION="1.0.0"
ENVIRONMENT=development       # development | production | test
DEBUG=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with:  openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Comma-separated. Never use JSON array format — plain URLs only.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Docker (local):  postgresql+asyncpg://postgres:postgres@db:5432/pathfinder
# Local dev:       postgresql+asyncpg://postgres:postgres@localhost:5432/pathfinder
# Supabase:        postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pathfinder
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false
# Set to true when connecting to Supabase or any remote Postgres requiring SSL
DATABASE_SSL=false
# Set to true when connecting through pgBouncer transaction mode (port 6543)
DATABASE_PGBOUNCER=false

# ── Redis ─────────────────────────────────────────────────────────────────────
# Docker:  redis://redis:6379/0
# Local:   redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
# REQUIRED in production
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# ── Pinecone (optional — leave blank to disable vector search) ────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=pathfinder-index

# ── Google OAuth (optional — leave blank to disable) ─────────────────────────
GOOGLE_CLIENT_ID=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=        # paste your 16-char Gmail App Password here (no spaces)
